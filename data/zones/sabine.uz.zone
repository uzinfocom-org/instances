$TTL 86400
@      IN    SOA    ns1.kolyma.uz. admin.kolyma.uz. (
             2026022201 ; Serial YYYYMMDDNN (NN is the revision number)
             3600       ; Refresh
             1800       ; Retry
             604800     ; Expire
             86400 )    ; Minimum TTL

; ==> Nameservers
@      IN    NS    ns1.kolyma.uz.
@      IN    NS    ns2.kolyma.uz.
@      IN    NS    ns3.kolyma.uz.
@      IN    NS    ns4.kolyma.uz.

; ==> Entry points
@      IN    A     91.212.89.25
www    IN    CNAME sabine.uz.

; ==> Main Endpoints
matrix        IN    CNAME sabine.uz.
mas           IN    CNAME sabine.uz.
chat          IN    CNAME sabine.uz.
push          IN    CNAME sabine.uz.

; Livemedia Endpoints
call          IN    CNAME sabine.uz.
livekit       IN    CNAME sabine.uz.
livekit-jwt   IN    CNAME sabine.uz.

; ==> Mail configurations
mail              IN  CNAME sabine.uz.
@                 IN  MX    10 mail.sabine.uz.
@                 IN  TXT   "v=spf1 a:mail.sabine.uz -all"
_submission._tcp  IN  SRV   5 0 587 mail.sabine.uz.
_submissions._tcp IN  SRV   5 0 465 mail.sabine.uz.
_imap._tcp        IN  SRV   5 0 143 mail.sabine.uz.
_imaps._tcp       IN  SRV   5 0 993 mail.sabine.uz.
_dmarc            IN  TXT   "v=DMARC1; p=none"
