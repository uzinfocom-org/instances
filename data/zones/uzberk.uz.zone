$TTL 86400
@      IN    SOA    ns1.kolyma.uz. admin.kolyma.uz. (
             2026022401 ; Serial YYYYMMDDNN (NN is the revision number)
             3600       ; Refresh
             1800       ; Retry
             604800     ; Expire
             86400 )    ; Minimum TTL

; ==> Nameservers (Uzinfocom Internal)
@      IN    NS    ns1.oss.uzinfocom.uz.
@      IN    NS    ns2.oss.uzinfocom.uz.

; ==> Nameservers (Kolyma Provided)
@      IN    NS    ns1.kolyma.uz.
@      IN    NS    ns2.kolyma.uz.
@      IN    NS    ns3.kolyma.uz.
@      IN    NS    ns4.kolyma.uz.

; ==> Server Points
ns1    IN    A     45.150.26.27
ns2    IN    A     45.150.26.30
ns3    IN    A     45.150.26.26
nsx    IN    A     45.150.26.120

; ==> Entry points
@      IN    A     45.150.26.27
www    IN    CNAME uzberk.uz.

; ==> Central Endpoints
; Auth Endpoints
auth         IN    CNAME ns1.uzberk.uz.
; Push Endpoints
push         IN    CNAME ns1.uzberk.uz.
; Web Client Endpoints
chat         IN    CNAME ns1.uzberk.uz.

; ==> Livemedia Endpoints
call         IN    CNAME ns2.uzberk.uz.
livekit      IN    CNAME ns2.uzberk.uz.
livekit-jwt  IN    CNAME ns2.uzberk.uz.

; ==> Main Server
mas          IN    CNAME ns1.uzberk.uz.
matrix       IN    CNAME ns1.uzberk.uz.

; ==> MG Server
mg           IN    CNAME ns3.uzberk.uz.
mas.mg       IN    CNAME ns3.uzberk.uz.
chat.mg      IN    CNAME ns3.uzberk.uz.
push.mg      IN    CNAME ns3.uzberk.uz.
matrix.mg    IN    CNAME ns3.uzberk.uz.

; ==> Plazma Server
plazma        IN    CNAME nsx.uzberk.uz.
mas.plazma    IN    CNAME nsx.uzberk.uz.
chat.plazma   IN    CNAME nsx.uzberk.uz.
push.plazma   IN    CNAME nsx.uzberk.uz.
matrix.plazma IN    CNAME nsx.uzberk.uz.

; ==> Mail configurations
mail              IN  CNAME ns1.uzberk.uz.
@                 IN  MX    10 mail.uzberk.uz.
@                 IN  TXT   "v=spf1 a:mail.uzberk.uz -all"
_submission._tcp  IN  SRV   5 0 587 mail.uzberk.uz.
_submissions._tcp IN  SRV   5 0 465 mail.uzberk.uz.
_imap._tcp        IN  SRV   5 0 143 mail.uzberk.uz.
_imaps._tcp       IN  SRV   5 0 993 mail.uzberk.uz.
_dmarc            IN  TXT   "v=DMARC1; p=none"
mail._domainkey IN TXT ( "v=DKIM1; k=rsa;"
	"p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQCj6WZi6FalCbJbbO/brb+7FuhGrPnZnQBHPE4UcjmK2z2uHr2q0XozyF9gJNV7j8wO35Cf86e7MC8OC0KVJCE+RaJ6pfNg5MGjh+QXBlHSvc2wc9dJs1fBxQfI+yCMNeKwroxug5haOTG4PdqcuUy7vDhstfkGJC/AA+ziM5rApwIDAQAB" )
