$TTL 86400
@      IN    SOA    ns1.kolyma.uz. admin.kolyma.uz. (
             2026022401 ; Serial YYYYMMDDNN (NN is the revision number)
             3600       ; Refresh
             1800       ; Retry
             604800     ; Expire
             86400 )    ; Minimum TTL

; ==> Nameservers (Uzinfocom Internal)
@      IN    NS    ns1.oss.uzinfocom.uz.
@      IN    NS    ns2.oss.uzinfocom.uz.

; ==> Nameservers (Kolyma Provided)
@      IN    NS    ns1.kolyma.uz.
@      IN    NS    ns2.kolyma.uz.
@      IN    NS    ns3.kolyma.uz.
@      IN    NS    ns4.kolyma.uz.

; ==> Entry points
@      IN    A     185.199.108.153
@      IN    A     185.199.109.153
@      IN    A     185.199.110.153
@      IN    A     185.199.111.153

; ==> Hydra Build Farm
hydra       IN    CNAME ns2.oss.uzinfocom.uz.
cache       IN    CNAME ns2.oss.uzinfocom.uz.

; ==> Telegram Bots
bot         IN    CNAME ns2.kolyma.uz.

; ==> GitHub Deployments
graph       IN    CNAME xinux-org.github.io.

; ==> CDN after runners server
cdn         IN    CNAME ns3.kolyma.uz.

; ==> GitHub Verifications
_github-challenge-xinux-org-org      IN      TXT      1a06c6d74b
